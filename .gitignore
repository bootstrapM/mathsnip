# Virtual environment (huge: PyTorch, Qt, etc. — never commit)
.venv/
venv/
env/

# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Downloaded OCR model weights / caches (if any land locally)
*.pth
*.onnx
.cache/

# Local runtime state (do not ship a user's config/history)
